#!/bin/sh
# Pre-commit validation hook — validates staged JSON files.
# TypeScript type-checking is handled by the GitHub Actions validate job.
# Run once to enable: git config core.hooksPath .githooks
set -e

GREEN='\033[0;32m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'

echo "${CYAN}▶ Pre-commit checks...${NC}"

# ── JSON validation ──────────────────────────────────────────────────────────
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACM | grep '\.json$' || true)

if [ -n "$STAGED_JSON" ]; then
  FILES=$(echo "$STAGED_JSON" | tr '\n' '|')
  docker run --rm -v "$(pwd):/app:ro" node:20-alpine node -e "
    const files = '${FILES}'.split('|').filter(Boolean);
    let ok = true;
    files.forEach(f => {
      try {
        JSON.parse(require('fs').readFileSync('/app/' + f, 'utf8'));
        console.log('  \u2713 ' + f);
      } catch(e) {
        console.error('  \u2717 ' + f + ': ' + e.message);
        ok = false;
      }
    });
    if (!ok) process.exit(1);
  " || {
    echo "${RED}✗ JSON validation failed. Fix errors above and try again.${NC}"
    exit 1
  }
fi

echo "${GREEN}✓ All checks passed.${NC}"
